# llama.cpp binaries and libraries (downloaded at setup)
bin/llama.cpp/llama-server/linux-x64/*
bin/llama.cpp/llama-server/linux-arm64/*
bin/llama.cpp/llama-server/darwin-x64/*
bin/llama.cpp/llama-server/darwin-arm64/*
bin/llama.cpp/llama-server/windows-x64/*
!bin/llama.cpp/llama-server/*/.gitkeep

